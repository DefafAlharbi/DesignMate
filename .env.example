# Copy this file to .env.local and fill in your key.
# Get an OpenRouter API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=YOUR_API_KEY_HERE

# Optional: override the model used for all agents (defaults to google/gemini-2.5-flash).
# Must be a valid OpenRouter model slug.
# OPENROUTER_MODEL=google/gemini-2.5-flash
